# HotHunter 环境变量配置（Freqtrade 原生 FREQTRADE__ 语法）
# 语法: FREQTRADE__SECTION__KEY=value 可覆盖任意配置字段
# 复制为 .env 后填入真实值: cp .env.example .env

# --- 币安 API 密钥 ---
FREQTRADE__EXCHANGE__KEY=your_binance_api_key_here
FREQTRADE__EXCHANGE__SECRET=your_binance_api_secret_here

# --- Telegram 通知 ---
FREQTRADE__TELEGRAM__ENABLED=true
FREQTRADE__TELEGRAM__TOKEN=your_telegram_bot_token_here
FREQTRADE__TELEGRAM__CHAT_ID=your_chat_id_here
