# HotHunter 环境变量配置（复制为 .env 后填入真实值）
# cp .env.example .env

# 币安 API 密钥（需要提现权限，建议仅用交易权限）
HOTHUNTER_EXCHANGE_KEY=your_binance_api_key_here
HOTHUNTER_EXCHANGE_SECRET=your_binance_api_secret_here

# Telegram 通知（可选，不配置则 disable 通知）
HOTHUNTER_TELEGRAM_TOKEN=your_telegram_bot_token_here
HOTHUNTER_TELEGRAM_CHAT_ID=your_telegram_chat_id_here
