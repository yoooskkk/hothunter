{
    "max_open_trades": 5,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "trading_mode": "spot",
    "dry_run": true,
    "dry_run_wallet": 100.0,
    "timeframe": "5m",
    "fiat_display_currency": "USD",
    "process_only_new_candles": true,
    "use_exit_signal": true,
    "exit_profit_only": false,
    "ignore_roi_if_entry_signal": false,
    "initial_state": "running",
    "startup_candle_count": 100,
    "cancel_open_orders_on_exit": true,
    "unfilledtimeout": {"entry": 60, "exit": 60},
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0
    },
    "order_types": {
        "entry": "limit",
        "exit": "limit",
        "emergency_exit": "market",
        "force_exit": "market",
        "stoploss": "market",
        "stoploss_on_exchange": false
    },
    "bot_name": "HotHunter_Dry",
    "position_adjustment_enable": true,
    "max_entry_position_adjustment": 2,
    "pairlists": [
        {"method": "StaticPairList", "allow_inactive": false},
        {
            "method": "VolumePairList",
            "number_assets": 25,
            "sort_key": "quoteVolume",
            "min_value": 100000,
            "refresh_period": 86400
        }
    ],
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {"enableRateLimit": true},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "BNB/USDT",
            "SOL/USDT",
            "DOGE/USDT"
        ],
        "pair_blacklist": []
    },
    "telegram": {
        "enabled": true,
        "token": "${HOTHUNTER_TELEGRAM_TOKEN}",
        "chat_id": "${HOTHUNTER_TELEGRAM_CHAT_ID}"
    },
    "api_server": {
        "enabled": false,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8080,
        "username": "",
        "password": ""
    }
}
